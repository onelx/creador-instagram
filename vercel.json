{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/json-prompt",
      "dest": "/api/json-prompt.js"
    },
    {
      "src": "/api/branding",
      "dest": "/api/branding.js"
    },
    {
      "src": "/",
      "dest": "/nano-banana.html"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/$1"
    }
  ]
}
